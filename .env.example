# Copy to .env and fill in. Never commit real keys.
HELIUS_API_KEY=

# Neon Postgres — pooled URL for the app (Vercel / `npm run dev`).
DATABASE_URL=
# Unpooled / direct URL for `npm run db:push`, migrate, and local admin scripts (Neon dashboard → Connection → “Direct”). Optional but fixes some P1001/timeouts.
# DIRECT_URL=

# First admin Solana wallet (base58). Used by `npm run db:seed` to insert into AdminWallet.
INITIAL_ADMIN_WALLET=
# Optional comma-separated extra admins for `npm run db:seed`
# ADDITIONAL_ADMIN_WALLETS=
# One-off: `npm run db:add-admin -- <pubkey> [label]`

# Long random string — required to sign in at /admin/login (HTTP-only cookie). Example: openssl rand -hex 32
ADMIN_DASHBOARD_SECRET=

# Profile social linking (Discord + X OAuth). Same secret style as admin; can reuse ADMIN_DASHBOARD_SECRET locally.
# AUTH_SECRET=
# AUTH_URL=https://slotto.gg
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=
# Required for Discord profile pictures (OAuth alone often saves embed/avatars/*.png by mistake).
# Discord Developer Portal → your app → Bot → Reset Token → copy here. Also add to Vercel env.
DISCORD_BOT_TOKEN=
# AUTH_TWITTER_ID=
# AUTH_TWITTER_SECRET=

# Canonical site URL for Open Graph / Twitter link previews (defaults to https://slotto.gg).
NEXT_PUBLIC_SITE_URL=https://slotto.gg
# Official @slottogg_ draw posts always append this URL (defaults to https://slotto.gg).
# Set only to override for staging tweet tests — preview vercel.app URLs are never used.
# LOTTERY_ANNOUNCE_SITE_URL=https://slotto.gg

# Browser RPC for wallet reads (public endpoint only — no api-key=, no bare helius-rpc.com host).
# Server Helius stays in HELIUS_API_KEY only (never NEXT_PUBLIC with api-key=).
# NEXT_PUBLIC_SOLANA_BROWSER_RPC_URL=https://api.mainnet-beta.solana.com
# Legacy name (ignored if URL contains api-key=): NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# Browser + Solscan cluster (required on Vercel when LOTTERY_CLUSTER is server-only).
NEXT_PUBLIC_LOTTERY_CLUSTER=mainnet-beta

# --- Vercel Production (mainnet) ---
# Required for auto-settle on slotto.vercel.app:
#   LOTTERY_CLUSTER=mainnet-beta
#   NEXT_PUBLIC_LOTTERY_CLUSTER=mainnet-beta
#   LOTTERY_KEEPER_SECRET_KEY=[...]   # full keypair JSON array
#   LOTTERY_VRF_MODE=switchboard
# RPC for server actions / crank (defaults to public cluster RPC):
#   LOTTERY_CLUSTER=mainnet-beta
#   LOTTERY_RPC_URL=https://api.mainnet-beta.solana.com   # optional override
#   LOTTERY_USE_HELIUS=true + HELIUS_API_KEY=...            # opt-in Helius for server only (not browser)
# HELIUS_API_KEY is still used for token metadata / DAS; not for lottery txs unless LOTTERY_USE_HELIUS=true
# Do NOT set LOTTERY_RPC_URL to devnet while LOTTERY_CLUSTER=mainnet-beta — admin will read devnet next_draw_id (e.g. 10) while Phantom uses mainnet.
# Settlement ignores NEXT_PUBLIC_SOLANA_RPC_URL (browser only).

# Deployed Anchor program id (base58). Must match `declare_id!` in `programs/slotto_lottery` after `anchor keys sync`.
# Local / devnet program id from `anchor keys list` after `npm run lottery:build`
NEXT_PUBLIC_SLOTTO_LOTTERY_PROGRAM_ID=6mYYxtJ4NPH1oNJoy2CpJGQq6XiWCsu8iB5y6ior6TMq

# SLOTTO FREE ENTRY giveaway token (set after `npm run lottery:mint-free-entry`).
# When set, it's auto-added to every new draw as a fixed-price option (1 token = 1
# free ticket) and shown in the buy dropdown only to wallets that hold it. Leave
# unset to disable the feature (safe no-op).
# NEXT_PUBLIC_FREE_ENTRY_MINT=

# Integration tests only (`npm run lottery:test:integration`). JSON keypair path — not ~/.config/solana/id.json.
# LOTTERY_TEST_WALLET=.keys/lottery-integration.json
# LOTTERY_TEST_PUBKEY=Hcm8gHTnsSENygdXihgnYUhxycVNtmtTNBLwybQiJAyh
# LOTTERY_TEST_REUSE_VALIDATOR=1  # keep local validator + ledger (default: fresh ledger each run)
# LOTTERY_DEVNET_RPC=https://api.devnet.solana.com
# LOTTERY_DEVNET_MIN_BALANCE=3
# Mainnet deploy wallet keypair path (defaults to LOTTERY_TEST_WALLET). Fund with ~4–5 SOL before deploy.
# LOTTERY_DEPLOY_WALLET=.keys/lottery-mainnet-deploy.json
# LOTTERY_MAINNET_MIN_BALANCE=4
# Mainnet rollout: docs/mainnet-rollout.md — npm run lottery:deploy:mainnet, lottery:init

# VRF mode for keeper crank: stub (devnet) | switchboard (mainnet). Default: stub on devnet RPC, switchboard on mainnet RPC.
# LOTTERY_VRF_MODE=stub
# Resume Switchboard settle when draw is already VrfRequested:
# LOTTERY_RANDOMNESS_ACCOUNT=

# Keeper: pays fees for permissionless close_sales → request_vrf → settle.
# Vercel: paste the full JSON array from your keypair file (do not commit the file):
# LOTTERY_KEEPER_SECRET_KEY=[1,2,3,...]
# Local: path to keypair file instead
# LOTTERY_KEEPER_WALLET=.keys/lottery-integration.json
# Vercel cron auth for GET /api/lottery/crank (homepage uses a server action instead).
# CRON_SECRET=  # openssl rand -hex 32 — Vercel cron sends Authorization: Bearer (see vercel.json)
# LOTTERY_CRON_SECRET=  # optional alias read by the crank API route
# Vercel Hobby: use GitHub Actions cron — .github/workflows/lottery-crank.yml (see docs/vercel-cron-hobby.md).
# Add the same CRON_SECRET as a GitHub repo secret. Leave public crank disabled:
# LOTTERY_PUBLIC_CRANK_ENABLED=false
# NEXT_PUBLIC_LOTTERY_PUBLIC_CRANK_ENABLED=false

# --- Official @slottogg_ X (Twitter) announcements: "draw live" + "draw ended" ---
# Separate from AUTH_TWITTER_* (login only). Requires an X app with "Read and write"
# permission and OAuth 1.0a user tokens generated for the @slottogg_ account.
# Leave SLOTTO_X_POSTING_ENABLED unset to keep posting OFF (safe no-op).
# Note: posts include a slotto.gg link, billed by X at ~$0.20/post (pay-per-use).
# SLOTTO_X_POSTING_ENABLED=true
# SLOTTO_X_APP_KEY=          # API key (consumer key)
# SLOTTO_X_APP_SECRET=       # API key secret (consumer secret)
# SLOTTO_X_ACCESS_TOKEN=     # Access token for @slottogg_
# SLOTTO_X_ACCESS_SECRET=    # Access token secret for @slottogg_

# Required on Vercel for admin project image uploads (filesystem is read-only there).
# Vercel dashboard → Storage → Create Blob Store → Connect to this project → redeploy.
# Local dev: optional (falls back to public/uploads/); or `vercel env pull`
BLOB_READ_WRITE_TOKEN=

# Production maintenance on slotto.gg (blur homepage + V2 overlay). *.vercel.app is unaffected.
# MAINTENANCE_MODE=true
# MAINTENANCE_BYPASS_SECRET=  # openssl rand -hex 32 — team unlock: /api/maintenance/unlock?key=...
# MAINTENANCE_HOSTS=slotto.gg,www.slotto.gg

# Homepage past winners + winner hero: hide test draws below this id (e.g. 9 hides draws 0–8).
# LOTTERY_PAST_WINNERS_MIN_DRAW_ID=9
