# Copy to .env and fill in. Never commit real keys.
HELIUS_API_KEY=

# Neon Postgres (pooled URL is fine for the app). For `prisma migrate` some setups need a direct (non-pooler) URL — see Neon docs.
DATABASE_URL=

# First admin Solana wallet (base58). Used by `npm run db:seed` to insert into AdminWallet.
INITIAL_ADMIN_WALLET=

# Long random string — required to sign in at /admin/login (HTTP-only cookie). Example: openssl rand -hex 32
ADMIN_DASHBOARD_SECRET=

# Optional: browser RPC for wallet / reads (defaults to public mainnet-beta). Use Helius only if the key is HTTP-referrer locked in dashboard.
NEXT_PUBLIC_SOLANA_RPC_URL=

# Vercel Blob (project image uploads on Vercel). Create a Blob store in the Vercel dashboard → Storage; this token is added automatically. For local dev: `vercel env pull`
BLOB_READ_WRITE_TOKEN=
