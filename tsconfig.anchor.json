{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["tests/**/*.ts", "target/types/**/*.ts"]
}
