// Slotto.gg — Neon Postgres
// https://www.prisma.io/docs/orm/prisma-schema/overview

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Optional: Neon recommends an unpooled URL for migrations when DATABASE_URL uses `-pooler`.
  // directUrl = env("DIRECT_URL")
}

// --- Auth.js (NextAuth) adapter tables — wire when Discord/Twitter login lands ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Admin: Solana wallet allowlist (SIWS / wallet gate later) ---

model AdminWallet {
  id        String    @id @default(cuid())
  /// Solana public key (base58), case-sensitive — store exactly as shown in wallet
  address   String    @unique
  label     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  projects  Project[]
}

// --- Site-wide admin toggles (singleton row id = "default") ---

model SiteSettings {
  id                  String   @id @default("default")
  /// Published project `slug` shown in the featured block on /projects; null = use env then likes
  featuredProjectSlug String?
  updatedAt           DateTime @updatedAt
}

// --- Public listings ---

model Project {
  id               String       @id @default(cuid())
  slug             String       @unique
  name             String
  tagline          String?
  likes            Int          @default(0)
  reviewMd         String       @db.Text
  meUrl            String?
  /// string[] — legacy; synced from `collections` Magic Eden links
  meUrls           Json?
  /// [{ name?, links: [{ marketplace, href }] }] — collections + marketplace URLs per collection
  collections      Json?
  discordUrl       String?
  twitterUrl       String?
  websiteUrl       String?
  tokenMint        String?
  /// When true (default), token is tradeable — Dex/Birdeye. When false, use tokenImageUrl and Solscan.
  tokenLiquid      Boolean      @default(true)
  /// Custom logo for non-liquid project tokens (URL or /uploads/…)
  tokenImageUrl    String?
  /// Display name for non-liquid tokens (e.g. BUX)
  tokenName        String?
  /// { floor, supply, listings, volume, sales24h } as strings for display
  stats            Json?
  /// legacy flat marketplace list — migrated into `collections`
  marketplaces     Json?
  bannerImageUrl   String?
  /// Square / ~1:1 image for directory & mobile listings (URL or /uploads/... from upload)
  listingImageUrl  String?
  published        Boolean      @default(false)
  createdById      String?
  createdBy        AdminWallet? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  projectLikes     ProjectLike[]

  @@index([published, likes])
  @@index([published, name])
}

/// One like per user profile per published project.
model ProjectLike {
  id            String      @id @default(cuid())
  projectId     String
  userProfileId String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([projectId, userProfileId])
  @@index([projectId])
  @@index([userProfileId])
}

// --- Lottery (one active draw; ticket rows keyed by wallet) ---

enum LotteryDrawStatus {
  ACTIVE
  COMPLETED
}

model LotteryDraw {
  id               String                @id @default(cuid())
  drawNumber       Int                   @unique
  status           LotteryDrawStatus     @default(ACTIVE)
  completedAt      DateTime?
  /// Denormalized / cached; profile API also sums purchases for pool display
  totalTicketsSold Int                   @default(0)
  winnerWallet     String?
  prizeSol         Decimal?              @db.Decimal(20, 9)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  purchases        LotteryTicketPurchase[]

  @@index([status])
}

model LotteryTicketPurchase {
  id            String      @id @default(cuid())
  drawId        String
  draw          LotteryDraw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  wallet        String
  tickets       Int
  /// string[] mint addresses used for payment chips (same convention as home draws)
  paidWithMints Json?
  createdAt     DateTime    @default(now())

  @@index([wallet])
  @@index([drawId])
}

// --- On-chain lottery SPL ops (draw_id = program `draw_id`, not LotteryDraw.id) ---

/// Reusable SPL ticket line items; loaded when admin creates a new draw.
model LotterySplCatalogEntry {
  id                 String   @id @default(cuid())
  mint               String   @unique
  symbol             String?
  label              String?
  mintDecimals       Int      @default(9)
  /// Fixed SPL amount per ticket (base units) until dynamic ≈0.095 SOL pricing.
  pricePerTicket     String
  defaultOnChainCap  Int      @default(500)
  defaultDisplayCap  Int      @default(60)
  defaultPublished   Boolean  @default(false)
  sortOrder          Int      @default(0)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

/// Per-draw SPL row: UI caps/flags; mirrors an on-chain mint row when registered.
model LotteryDrawSplMint {
  id              String   @id @default(cuid())
  onChainDrawId   Int
  mint            String
  onChainCap      Int
  displayCap      Int
  published       Boolean  @default(false)
  purchasesLocked Boolean  @default(false)
  symbol          String?
  pricePerTicket  String
  mintDecimals    Int      @default(9)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([onChainDrawId, mint])
  @@index([onChainDrawId])
}

/// Idempotency guard for official @slottogg_ X announcements (one per draw+kind).
enum LotteryAnnouncementKind {
  LIVE
  ENDED
}

model LotteryDrawAnnouncement {
  id            String                  @id @default(cuid())
  onChainDrawId Int
  kind          LotteryAnnouncementKind
  tweetId       String?
  postedAt      DateTime                @default(now())

  @@unique([onChainDrawId, kind])
  @@index([onChainDrawId])
}

// --- User profile: Discord / X + many linked wallets ---

model UserProfile {
  id                 String         @id @default(cuid())
  discordId          String?        @unique
  discordUsername    String?
  discordDisplayName String?
  discordAvatarUrl   String?
  discordAvatarHash  String?
  xId                String?        @unique
  xHandle            String?
  xAvatarUrl         String?
  linkedWallets      LinkedWallet[]
  projectLikes       ProjectLike[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model LinkedWallet {
  id            String      @id @default(cuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  wallet        String      @unique
  verifiedAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())

  @@index([userProfileId])
}
